class Solution {
    public String reverseWords(String s) {

        char ans[]=s.toCharArray();
        int right=0,left=0;

        while(ans.length>right){

            if(ans[right] == ' '){
                reverse(ans,left,right-1);
                left=right+1;
            }

            right++;
        }

        reverse(ans,left,right-1);

        return new String(ans);
        
    }

    private void reverse(char[] ans,int left,int right){
        while(left<right){
        char temp=ans[left];
        ans[left++]=ans[right];
        ans[right--]=temp;
        }
    }
}
