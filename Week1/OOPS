import java.util.*;

public class LibraryInterfaceDemo {

    public static void main(String[] args) {
        KidUsers monty=new KidUsers();
        monty.age=10;
        monty.registerAccount();
        monty.age=18;
        monty.registerAccount();
        monty.bookType="Kids";
        monty.requestBook();
        monty.bookType="Fiction";
        monty.requestBook();

        AdultUsers Rohit=new AdultUsers();
        Rohit.age=5;
        Rohit.registerAccount();
        Rohit.age=21;
        Rohit.registerAccount();
        Rohit.bookType="kids";
        Rohit.requestBook();
        Rohit.bookType="Fiction";
        Rohit.requestBook();
    }
    
    
    public interface LibraryUser {
    
        void registerAccount();
        void requestBook();
    }
    
    static class KidUsers implements LibraryUser{
        int age;
        String bookType;

    public  void registerAccount(){
        if(age<12){
            System.out.println("You have successfully registered under a Kids Account");
        }else{
            System.out.println("Sorry, Age must be less than 12 to register as a kid");
        }
    }
    public void requestBook(){
      if(bookType == "Kids"){
        System.out.println("Book Issued successfully, please return the book within 10 days");
      }else{
        System.out.println("Oops, you are allowed to take only kids books");
      }

    }

    }
    static class AdultUsers implements LibraryUser{

        int age;
        String bookType;

        public void registerAccount(){
            if(age>12){
                System.out.println("You have successfully registered under an Adult Account");
            }else{
                System.out.println("Sorry, Age must be greater than 12 to register as an adult");
            }
        }

        public void requestBook(){
            if(bookType=="Fiction"){
                System.out.println("Book Issued successfully, please return the book within 7 days");
            }else{
                System.out.println("Oops, you are allowed to take only adult Fiction books");
            }
        }
    }
}


