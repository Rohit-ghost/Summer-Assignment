class Solution {
    public int maxProfit(int[] arr) {
        int maxp=0;
        int bb=arr[0];
        int diff=0;

        for(int i=1;i<arr.length;i++){
            if(bb>arr[i]){
                bb=arr[i];
                continue;
            }

            diff=arr[i]-bb;
            if(diff>maxp){
                maxp=diff;
            }
            
        }

        return maxp;
    }
}
