class Solution {
    public String longestCommonPrefix(String[] strs) {
        String ans=strs[0];
        for(int i=1;i<strs.length;i++){
            String temp="";
            int m=Math.min(strs[i].length(),ans.length());
            for(int j=0;j<m;j++){
                if(ans.charAt(j) == strs[i].charAt(j)){
                    temp=temp+ans.charAt(j);
                }else{
                    break;
                }
            }
            ans=temp;

            if(ans==""){
                return "";
            }
        }
        
        return ans;
    }
}



