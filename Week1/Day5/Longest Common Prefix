class Solution {
    public String longestCommonPrefix(String[] strs) {
        if (strs == null || strs.length == 0) {
            return "";
        }
        
        String ans = strs[0];
        
        for (int i = 1; i < strs.length; i++) {
            int j = 0;
            int m = Math.min(strs[i].length(), ans.length());
            
            while (j < m && strs[i].charAt(j) == ans.charAt(j)) {
                j++;
            }
            
            ans = ans.substring(0, j);
            
            if (ans.isEmpty()) {
                return "";
            }
        }
        
        return ans;
    }
}



