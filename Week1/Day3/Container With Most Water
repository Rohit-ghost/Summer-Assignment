class Solution {
    public int maxArea(int[] height) {
        int st=0;
        int end=height.length-1;

        int maxWat=0;

        while(st<end){
            int h=Math.min(height[st],height[end]);
            int area=h*(end-st);
            if(maxWat<area){
                maxWat=area;
            }

            if(height[st]>height[end]){
                end--;
            }else{
                st++;
            }
        }
        
        return maxWat;
    }
}
